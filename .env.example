# ─────────────────────────────────────────────────────────────
# The Arc Beauty — environment variables
# Copy to .env.local and fill in. Every integration degrades
# gracefully when its keys are absent, so the site runs without them.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for metadata + checkout redirects)
NEXT_PUBLIC_SITE_URL=https://thearcbeautyservice.com

# ── Hero video (optional) ──
# Until set, the hero shows the editorial Full-HD image.
NEXT_PUBLIC_HERO_VIDEO=

# ── Square — payments (products & gift cards) ──
# Online Checkout API (hosted payment link). Until set, /checkout falls back
# to "reserve by phone". Use Sandbox creds + SQUARE_ENVIRONMENT=sandbox to test.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# ── Square Appointments — real-time booking ──
# Your published Square booking site URL
# (Dashboard → Appointments → online booking site → copy link).
# Until set, booking shows a concierge call/email card.
NEXT_PUBLIC_SQUARE_BOOKING_URL=

# ── Google Places — live rating + reviews ──
# Until set, /api/reviews serves the curated reviews from lib/data.ts.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Resend — transactional email (optional) ──
RESEND_API_KEY=
