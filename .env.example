# ─────────────────────────────────────────────────────────────
# The Arc Beauty — environment variables
# Copy to .env.local and fill in. Every integration degrades
# gracefully when its keys are absent, so the site runs without them.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for metadata + checkout redirects)
NEXT_PUBLIC_SITE_URL=https://thearcbeautyservice.com

# ── Hero video (cinematic, treatments + product textures) ──
# Until set, the hero shows on-brand editorial placeholder art.
# Point to an MP4 (e.g. /hero.mp4 in /public, or a CDN URL).
NEXT_PUBLIC_HERO_VIDEO=

# ── Stripe — payments, products, gift cards ──
# Until set, /checkout falls back to "reserve by phone".
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Cal.com — real-time booking (white-label) ──
# Your cal.com username/team slug, e.g. "thearcbeauty".
# Until set, booking shows a concierge call/email card.
NEXT_PUBLIC_CALCOM_LINK=

# ── Google Places — live rating + reviews ──
# Until set, /api/reviews serves the curated reviews from lib/data.ts.
# Note: the Places API returns at most 5 reviews; the full wall stays curated.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Resend — transactional email (optional) ──
RESEND_API_KEY=
